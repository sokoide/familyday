# Google Gemini API キー(必須)。Google AI Studio で発行。
GEMINI_API_KEY=

# 公開ベースURL(絶対URL生成用・QR/画像URLに使う)。本番は https://example.com
PUBLIC_BASE_URL=http://localhost:8080

# 待受ポート
PORT=8080

# データ格納ディレクトリ(エンディングJSON・生成画像)。
# 2026/server をカレントディレクトリにして起動する前提の相対パス。
DATA_DIR=data

# フロント静的配信ディレクトリ(Vite ビルド成果物)。
STATIC_DIR=static

# --- Gemini モデル(任意・空欄でデフォルト) ---
# 判定/ストーリー: gemini-3.1-flash-lite
#GEMINI_MODEL_JUDGE=gemini-3.1-flash-lite
#GEMINI_MODEL_STORY=gemini-3.1-flash-lite
# 画像: gemini-3.1-flash-lite-image (Nano Banana Lite / generate_content)
#GEMINI_MODEL_IMAGE=gemini-3.1-flash-lite-image

# --- 画像生成オプション(任意) ---
# 画像の1辺(px・正方形)。既定1024=モデルのネイティブ出力(リサイズなし)。
# 1024以外にすると生成後にサーバ側でリサイズ(他モデル移行時や縮小用途)。
#GEMINI_IMAGE_SIZE=1024
# 生成候補数。既定1=非バッチ。>1 だと最初の成功を採用するまで複数回生成(コストN倍)。
#GEMINI_IMAGE_COUNT=1
