# Google Gemini API キー(必須)。Google AI Studio で発行。
GEMINI_API_KEY=

# 公開ベースURL(絶対URL生成用・QR/画像URLに使う)。本番は https://example.com
PUBLIC_BASE_URL=http://localhost:8080

# 待受ポート
PORT=8080

# データ格納ディレクトリ(エンディングJSON・生成画像)。
# 2026/server をカレントディレクトリにして起動する前提の相対パス。
DATA_DIR=data

# フロント静的配信ディレクトリ(Vite ビルド成果物)。
STATIC_DIR=static

# --- Gemini モデル(任意・空欄でデフォルト) ---
# 判定: gemini-3.1-flash-lite
#GEMINI_MODEL_JUDGE=gemini-3.1-flash-lite
# エンディング要約: gemini-3.1-flash-lite
#GEMINI_MODEL_STORY=gemini-3.1-flash-lite
